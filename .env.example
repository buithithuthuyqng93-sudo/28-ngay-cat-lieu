# Copy this file to .env and fill in the values.

# PostgreSQL (Neon) connection string used by Prisma
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# Secret key used to sign session cookies (generate your own, e.g. `openssl rand -base64 32`)
SESSION_SECRET="replace-with-a-random-32-byte-base64-secret"

# Public base URL of this app — used to build the confirmation email link. Not a secret.
APP_URL="http://localhost:3000"

# SePay — bank transaction webhook payment gateway (my.sepay.vn). Never commit real values.
# Webhook API Key: SePay Dashboard > Tich hop WebHooks > tao webhook, chon xac thuc API Key
SEPAY_WEBHOOK_API_KEY="replace-with-your-sepay-webhook-api-key"
# User API Token: SePay Dashboard > API, dung de doi chieu giao dich du phong
SEPAY_USER_API_TOKEN="replace-with-your-sepay-user-api-token"
# Bank account connected to SePay that receives payments. Not a secret (shown on the QR).
SEPAY_BANK_ACCOUNT="0000000000"
SEPAY_BANK_NAME="MBBank"

# Resend — transactional email (resend.com). Never commit real values.
RESEND_API_KEY="replace-with-your-resend-api-key"
# Must be on a domain verified in your Resend account.
EMAIL_FROM="noreply@your-verified-domain.com"
