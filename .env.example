# Copy this file to .env and fill in the values.

# PostgreSQL (Neon) connection string used by Prisma
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# Secret key used to sign session cookies (generate your own, e.g. `openssl rand -base64 32`)
SESSION_SECRET="replace-with-a-random-32-byte-base64-secret"

# PayOS payment gateway credentials — from your PayOS Business payment channel settings
# (https://business.payos.vn). Never commit real values.
PAYOS_CLIENT_ID="replace-with-your-payos-client-id"
PAYOS_API_KEY="replace-with-your-payos-api-key"
PAYOS_CHECKSUM_KEY="replace-with-your-payos-checksum-key"

# Public base URL of this app — used to build PayOS returnUrl/cancelUrl. Not a secret.
APP_URL="http://localhost:3000"
